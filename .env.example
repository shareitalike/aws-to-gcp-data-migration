# ─── AWS Credentials ───
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=your-migration-demo-bucket

# ─── GCP Settings ───
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=us-central1
GCS_BUCKET_RAW=your-project-data-lake-raw
GCS_BUCKET_VALIDATED=your-project-data-lake-validated
GCS_BUCKET_QUARANTINE=your-project-data-lake-quarantine
GCS_BUCKET_PROCESSED=your-project-data-lake-processed

# ─── BigQuery ───
BQ_DATASET_STAGING=staging
BQ_DATASET_ANALYTICS=analytics
BQ_TABLE_STAGING=enriched_orders_staging
BQ_TABLE_PRODUCTION=enriched_orders

# ─── GCP Auth ───
# Point this to your service account JSON key file
GOOGLE_APPLICATION_CREDENTIALS=path/to/your-service-account-key.json
